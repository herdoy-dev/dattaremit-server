generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String  @id @default(uuid()) @db.Uuid
  firstName             String
  clerkUserId           String  @unique
  zynkEntityId          String?
  zynkExternalAccountId String?
  zynkDepositAccountId  String?
  lastName              String
  email                 String // Encrypted email
  emailHash             String  @unique // HMAC-SHA256 hash for lookups
  phoneNumberPrefix     String
  phoneNumber           String
  dateOfBirth           String // Encrypted date of birth (stored as ISO string)
  nationality           String?

  referCode       String?       @unique
  referredByCode  String?
  referValue      Int           @default(1)

  role            UserRole      @default(USER)
  accountStatus   AccountStatus @default(INITIAL)
  achPushEnabled  Boolean       @default(false)
  addresses     Address[]
  activities    Activity[]
  notifications Notification[]
  devices       UserDevice[]
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  @@index([referredByCode])
  @@index([zynkEntityId])
  @@index([created_at])
  @@map("users")
}

model Address {
  id           String      @id @default(uuid()) @db.Uuid
  type         AddressType @default(PRESENT)
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String
  postalCode   String
  isDefault    Boolean     @default(false)
  userId       String      @db.Uuid
  user         User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@map("addresses")
}

enum AddressType {
  PRESENT
  PERMANENT

  @@map("address_type")
}

enum UserRole {
  ADMIN
  USER
  INFLUENCER
  PROMOTER

  @@map("user_role")
}

enum AccountStatus {
  INITIAL
  ACTIVE
  PENDING
  REJECTED
  DELETED

  @@map("account_status")
}

enum IdempotencyStatus {
  PENDING
  COMPLETED
  FAILED

  @@map("idempotency_status")
}

enum ActivityStatus {
  PENDING
  FAILED
  COMPLETE

  @@map("activity_status")
}

enum ActivityType {
  // Financial activities
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  PAYMENT
  REFUND

  // KYC activities
  KYC_SUBMITTED
  KYC_APPROVED
  KYC_REJECTED
  KYC_PENDING
  KYC_VERIFIED
  KYC_FAILED

  // Account activities
  ACCOUNT_APPROVED
  ACCOUNT_ACTIVATED
  ACCOUNT_DEACTIVATED

  // Admin activities
  ADMIN_ACTION

  @@map("activity_type")
}

model Activity {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @db.Uuid
  user        User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  type        ActivityType
  status      ActivityStatus @default(PENDING)
  description String?
  amount      Decimal?       @db.Decimal(18, 6)
  metadata    Json?
  referenceId String?        @db.Uuid
  ipAddress   String?
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([referenceId])
  @@index([created_at])
  @@map("activities")
}

model IdempotencyKey {
  id             String            @id @default(uuid()) @db.Uuid
  key            String
  userId         String            @db.Uuid
  operation      String
  status         IdempotencyStatus @default(PENDING)
  requestHash    String?
  responseStatus Int?
  responseBody   Json?
  errorMessage   String?
  expiresAt      DateTime
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt

  @@unique([userId, operation, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

enum NotificationType {
  KYC_APPROVED
  KYC_REJECTED
  KYC_FAILED
  KYC_PENDING
  ACCOUNT_ACTIVATED
  TRANSACTION_INITIATED
  TRANSACTION_COMPLETED
  TRANSACTION_FAILED
  PROMOTIONAL
  SYSTEM_ALERT
  REFERRAL_BONUS
  PROFILE_UPDATED
  PASSWORD_CHANGED

  @@map("notification_type")
}

enum DevicePlatform {
  IOS
  ANDROID

  @@map("device_platform")
}

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @db.Uuid
  user       User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  type       NotificationType
  title      String           @db.VarChar(255)
  body       String           @db.VarChar(1000)
  metadata   Json?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  created_at DateTime         @default(now())

  @@index([userId, created_at(sort: Desc)])
  @@index([userId, isRead])
  @@map("notifications")
}

model UserDevice {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @db.Uuid
  user          User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  platform      DevicePlatform
  expoPushToken String         @unique
  deviceName    String?        @db.VarChar(255)
  lastActiveAt  DateTime       @default(now())
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt

  @@index([userId])
  @@map("user_devices")
}

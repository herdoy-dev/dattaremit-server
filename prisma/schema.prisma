generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String  @id @default(uuid()) @db.Uuid
  firstName             String
  clerkUserId           String  @unique
  zynkEntityId          String?
  zynkExternalAccountId String?
  zynkDepositAccountId  String?
  lastName              String
  email                 String // Encrypted email
  emailHash             String  @unique // HMAC-SHA256 hash for lookups
  phoneNumberPrefix     String
  phoneNumber           String
  dateOfBirth           String // Encrypted date of birth (stored as ISO string)
  nationality           String?

  referCode       String?       @unique
  referredByCode  String?
  referValue      Int           @default(1)

  role            UserRole      @default(USER)
  accountStatus   AccountStatus @default(INITIAL)
  achPushEnabled  Boolean       @default(false)
  addresses     Address[]
  activities    Activity[]
  notifications Notification[]
  devices              UserDevice[]
  recipients           Recipient[]   @relation("userRecipients")
  sentTransactions     Transaction[] @relation("sentTransactions")
  receivedTransactions Transaction[] @relation("receivedTransactions")
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  @@index([referredByCode])
  @@index([zynkEntityId])
  @@index([created_at])
  @@map("users")
}

model Address {
  id           String      @id @default(uuid()) @db.Uuid
  type         AddressType @default(PRESENT)
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String
  postalCode   String
  isDefault    Boolean     @default(false)
  userId       String      @db.Uuid
  user         User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@map("addresses")
}

enum AddressType {
  PRESENT
  PERMANENT

  @@map("address_type")
}

enum UserRole {
  ADMIN
  USER
  INFLUENCER
  PROMOTER

  @@map("user_role")
}

enum AccountStatus {
  INITIAL
  ACTIVE
  PENDING
  REJECTED
  DELETED

  @@map("account_status")
}

enum RecipientKycStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED

  @@map("recipient_kyc_status")
}

model Recipient {
  id                   String              @id @default(uuid()) @db.Uuid
  createdByUserId      String              @db.Uuid
  createdByUser        User                @relation("userRecipients", fields: [createdByUserId], references: [id], onDelete: Restrict)

  firstName            String
  lastName             String
  email                String
  emailHash            String
  phoneNumberPrefix    String
  phoneNumber          String
  dateOfBirth          String

  nationality          String              @default("IN")
  addressLine1         String
  addressLine2         String?
  city                 String
  state                String
  country              String              @default("IN")
  postalCode           String

  zynkEntityId         String?
  zynkDepositAccountId String?
  kycStatus            RecipientKycStatus  @default(PENDING)
  kycLink              String?

  bankName             String?
  bankAccountNumber    String?
  bankIfsc             String?

  receivedTransactions Transaction[]       @relation("recipientTransactions")

  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt

  @@index([createdByUserId])
  @@index([zynkEntityId])
  @@unique([createdByUserId, emailHash])
  @@map("recipients")
}

enum IdempotencyStatus {
  PENDING
  COMPLETED
  FAILED

  @@map("idempotency_status")
}

enum ActivityStatus {
  PENDING
  FAILED
  COMPLETE

  @@map("activity_status")
}

enum ActivityType {
  // Financial activities
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  PAYMENT
  REFUND

  // KYC activities
  KYC_SUBMITTED
  KYC_APPROVED
  KYC_REJECTED
  KYC_PENDING
  KYC_VERIFIED
  KYC_FAILED

  // Account activities
  ACCOUNT_APPROVED
  ACCOUNT_ACTIVATED
  ACCOUNT_DEACTIVATED

  // Admin activities
  ADMIN_ACTION

  @@map("activity_type")
}

model Activity {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @db.Uuid
  user        User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  type        ActivityType
  status      ActivityStatus @default(PENDING)
  description String?
  amount      Decimal?       @db.Decimal(18, 6)
  metadata    Json?
  referenceId String?        @db.Uuid
  ipAddress   String?
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([referenceId])
  @@index([created_at])
  @@map("activities")
}

model IdempotencyKey {
  id             String            @id @default(uuid()) @db.Uuid
  key            String
  userId         String            @db.Uuid
  operation      String
  status         IdempotencyStatus @default(PENDING)
  requestHash    String?
  responseStatus Int?
  responseBody   Json?
  errorMessage   String?
  expiresAt      DateTime
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt

  @@unique([userId, operation, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

enum NotificationType {
  KYC_APPROVED
  KYC_REJECTED
  KYC_FAILED
  KYC_PENDING
  ACCOUNT_ACTIVATED
  TRANSACTION_INITIATED
  TRANSACTION_COMPLETED
  TRANSACTION_FAILED
  PROMOTIONAL
  SYSTEM_ALERT
  REFERRAL_BONUS
  PROFILE_UPDATED
  PASSWORD_CHANGED

  @@map("notification_type")
}

enum DevicePlatform {
  IOS
  ANDROID

  @@map("device_platform")
}

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @db.Uuid
  user       User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  type       NotificationType
  title      String           @db.VarChar(255)
  body       String           @db.VarChar(1000)
  metadata   Json?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  created_at DateTime         @default(now())

  @@index([userId, created_at(sort: Desc)])
  @@index([userId, isRead])
  @@map("notifications")
}

model UserDevice {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @db.Uuid
  user          User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  platform      DevicePlatform
  expoPushToken String         @unique
  deviceName    String?        @db.VarChar(255)
  lastActiveAt  DateTime       @default(now())
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt

  @@index([userId])
  @@map("user_devices")
}

enum TransactionStatus {
  SIMULATED
  ACCEPTED
  PROCESSING
  COMPLETED
  FAILED

  @@map("transaction_status")
}

model Transaction {
  id                String            @id @default(uuid()) @db.Uuid
  senderId          String            @db.Uuid
  sender            User              @relation("sentTransactions", fields: [senderId], references: [id], onDelete: Restrict)
  receiverId        String?           @db.Uuid
  receiver          User?             @relation("receivedTransactions", fields: [receiverId], references: [id], onDelete: Restrict)
  recipientId       String?           @db.Uuid
  recipient         Recipient?        @relation("recipientTransactions", fields: [recipientId], references: [id], onDelete: Restrict)

  zynkTransactionId String            @unique
  zynkExecutionId   String?

  sendAmount        Decimal           @db.Decimal(18, 6)
  sendCurrency      String            @default("USD")
  receiveAmount     Decimal?          @db.Decimal(18, 6)
  receiveCurrency   String            @default("INR")
  exchangeRate      Decimal?          @db.Decimal(18, 6)
  totalFees         Decimal?          @db.Decimal(18, 6)
  feeCurrency       String?           @default("USD")

  status            TransactionStatus @default(SIMULATED)
  depositMemo       String?
  simulateResponse  Json?
  transferResponse  Json?
  failureReason     String?

  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  @@index([senderId])
  @@index([receiverId])
  @@index([recipientId])
  @@index([status])
  @@index([created_at])
  @@map("transactions")
}

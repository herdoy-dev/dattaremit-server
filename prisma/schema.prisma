generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String            @id @default(uuid()) @db.Uuid
  firstName            String
  clerkUserId          String            @unique
  zynkEntityId         String?
  zynkFundingAccountId String?
  lastName             String
  email                String // Encrypted email
  emailHash            String            @unique // HMAC-SHA256 hash for lookups
  phoneNumberPrefix    String
  phoneNumber          String
  dateOfBirth          String // Encrypted date of birth (stored as ISO string)

  accountStatus        AccountStatus     @default(INITIAL)
  addresses            Address[]
  externalAccounts     ExternalAccount[]
  teleport             Teleport?
  activities           Activity[]
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt

  @@map("users")
}

model Address {
  id           String      @id @default(uuid()) @db.Uuid
  type         AddressType @default(PRESENT)
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String
  postalCode   String
  isDefault    Boolean     @default(false)
  userId       String      @db.Uuid
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@map("addresses")
}

enum AddressType {
  PRESENT
  PERMANENT

  @@map("address_type")
}

model ExternalAccount {
  id                    String                @id @default(uuid()) @db.Uuid
  userId                String                @db.Uuid
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  zynkExternalAccountId String?               @unique
  walletAddress         String
  walletId              String?
  label                 String?
  type                  String                @default("withdrawal")
  status                ExternalAccountStatus @default(ACTIVE)
  teleports             Teleport[]
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  deleted_at            DateTime?

  @@unique([userId])
  @@index([userId, status])
  @@map("external_accounts")
}

model Teleport {
  id                String          @id @default(uuid()) @db.Uuid
  userId            String          @unique @db.Uuid
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalAccountId String          @db.Uuid
  externalAccount   ExternalAccount @relation(fields: [externalAccountId], references: [id], onDelete: Cascade)
  zynkTeleportId    String?         @unique
  status            TeleportStatus  @default(ACTIVE)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  @@map("teleports")
}

enum ExternalAccountStatus {
  ACTIVE
  INACTIVE

  @@map("external_account_status")
}

enum TeleportStatus {
  ACTIVE
  INACTIVE

  @@map("teleport_status")
}

enum AccountStatus {
  INITIAL
  ACTIVE
  PENDING
  REJECTED

  @@map("account_status")
}

enum IdempotencyStatus {
  PENDING
  COMPLETED
  FAILED

  @@map("idempotency_status")
}

enum ActivityStatus {
  PENDING
  FAILED
  COMPLETE

  @@map("activity_status")
}

enum ActivityType {
  // Financial activities
  DEPOSIT
  WITHDRAWAL
  EXTERNAL_ACCOUNT_ADDED
  EXTERNAL_ACCOUNT_REMOVED
  TRANSFER
  PAYMENT
  REFUND

  // KYC activities
  KYC_SUBMITTED
  KYC_APPROVED
  KYC_REJECTED
  KYC_PENDING
  KYC_VERIFIED
  KYC_FAILED

  // Account activities
  ACCOUNT_APPROVED
  ACCOUNT_ACTIVATED

  @@map("activity_type")
}

model Activity {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @db.Uuid
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ActivityType
  status      ActivityStatus @default(PENDING)
  description String?
  amount      Decimal?       @db.Decimal(18, 6)
  metadata    Json?
  referenceId String?        @db.Uuid
  ipAddress   String?
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([referenceId])
  @@map("activities")
}

model IdempotencyKey {
  id             String            @id @default(uuid()) @db.Uuid
  key            String
  userId         String            @db.Uuid
  operation      String
  status         IdempotencyStatus @default(PENDING)
  requestHash    String?
  responseStatus Int?
  responseBody   Json?
  errorMessage   String?
  expiresAt      DateTime
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt

  @@unique([userId, operation, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model KeyBackup {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @db.Uuid
  payload    Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("key_backups")
}
